# Django Settings
SECRET_KEY=replace-this-with-a-secure-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Neo4j "Brain Map" Configuration
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace-me-with-neo4j-password

# Multi-Modal & AI Keys
# Provider can be 'gemini' or 'openai'
LLM_PROVIDER=gemini
LLM_MODEL=gemini-3.1-flash-lite-preview
OPENAI_API_KEY=sk-replace-with-openai-key
GOOGLE_API_KEY=your-gemini-key
LLAMA_CLOUD_API_KEY=llx-replace-with-llamaparse-key